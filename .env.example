# Expo app (local .env — never commit real keys)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets)
# Required:
# OPENAI_API_KEY=
# Local scripts only (e.g. python3 scripts/remove-bg-main-character.py):
# REMOVE_BG_API_KEY=   # https://www.remove.bg/api

# Also add REMOVE_BG_API_KEY in Supabase → Edge Functions → Secrets for in-app generation.
